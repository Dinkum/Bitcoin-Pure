        "max_allocs_per_op_regression_pct": 15
      },
      {
        "name": "BenchmarkTxValidation",
        "max_ns_per_op_regression_pct": 15,
        "max_bytes_per_op_regression_pct": 15,
        "max_allocs_per_op_regression_pct": 15
      },
      {
        "name": "BenchmarkMempoolSelection",
        "max_ns_per_op_regression_pct": 15,
        "max_bytes_per_op_regression_pct": 15,
        "max_allocs_per_op_regression_pct": 15
      },
      {
        "name": "BenchmarkBlockApply",
        "max_ns_per_op_regression_pct": 15,
        "max_bytes_per_op_regression_pct": 15,
        "max_allocs_per_op_regression_pct": 15
